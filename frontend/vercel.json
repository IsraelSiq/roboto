{
  "version": 2,
  "outputDirectory": ".",
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "$VERCEL_API_URL/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET,POST,OPTIONS",
        "Access-Control-Allow-Headers": "Authorization,Content-Type"
      }
    },
    {
      "src": "/reports",
      "dest": "/reports.html"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "/$1.html",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
