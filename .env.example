# ============================================================
# Roboto — variáveis de ambiente
# Copie para .env e preencha com seus valores reais.
# NUNCA faça commit do .env!
# ============================================================

# ---- Binance (TESTNET — sandbox gratuito) -------------------
# 1. Acesse https://testnet.binance.vision
# 2. Faça login com GitHub
# 3. Clique em "Generate HMAC_SHA256 Key"
# 4. Copie API Key e Secret abaixo
BINANCE_API_KEY=sua_binance_api_key_testnet
BINANCE_SECRET=sua_binance_secret_testnet
BINANCE_TESTNET=true

# Para produção real:
# BINANCE_TESTNET=false
# BINANCE_API_KEY=sua_binance_api_key_real
# BINANCE_SECRET=sua_binance_secret_real

# ---- Supabase ----------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sua_supabase_service_role_key

# ---- News API ----------------------------------------------
NEWSAPI_KEY=sua_newsapi_key

# ---- API ---------------------------------------------------
API_TOKEN=um_token_secreto_qualquer

# ---- CORS (#30) --------------------------------------------
# Lista separada por vírgula de origens permitidas.
# Após deploy Vercel, troque * pelo URL real:
# ALLOWED_ORIGINS=https://roboto-dashboard.vercel.app
ALLOWED_ORIGINS=*

# ---- Warmup FinBERT ----------------------------------------
WARMUP_ON_STARTUP=false

# ---- Deploy (#30) ------------------------------------------
# Render Deploy Hook (cole o URL do painel Render):
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-xxxx?key=yyyy
