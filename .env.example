# ============================================================
# Roboto — Template de variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA faça commit do arquivo .env!
# ============================================================

# --- Binance ---
# Gere em: https://testnet.binance.vision (para testnet)
# ou em: https://www.binance.com/en/my/settings/api-management (para real)
BINANCE_API_KEY=sua_binance_api_key_aqui
BINANCE_SECRET=seu_binance_secret_aqui
BINANCE_TESTNET=true   # true = testnet | false = conta real

# --- Supabase ---
# Encontre em: Settings > API no painel do Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sua_supabase_anon_key_aqui

# --- Telegram (alertas do bot) ---
# Crie um bot em @BotFather e obtenha o token
# Para o chat_id: mande uma mensagem ao bot e acesse
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Configurações do robô ---
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=5m
INITIAL_BALANCE=10000
MAX_TRADES_PER_DAY=10
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MAX_DRAWDOWN_PCT=0.20
MAX_CONSECUTIVE_LOSSES=3

# --- App ---
ENV=development   # development | production
PORT=8000
