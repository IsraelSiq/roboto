# API Auth
# Bearer token para proteger POST /bot/start, /bot/stop, /bot/resume
# Gere um token seguro: python -c "import secrets; print(secrets.token_hex(32))"
# Deixe em branco para desativar a auth (modo dev local apenas)
API_TOKEN=

# News Cache
NEWS_CACHE_TTL_MINUTES=15
