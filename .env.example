# ============================================================
# Roboto — variáveis de ambiente
# Copie para .env e preencha com seus valores reais.
# NUNCA faça commit do .env!
# ============================================================

# ---- Binance -----------------------------------------------
BINANCE_API_KEY=sua_binance_api_key
BINANCE_SECRET=sua_binance_secret
BINANCE_TESTNET=false          # true para usar testnet

# ---- Supabase ----------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sua_supabase_service_role_key

# ---- News API ----------------------------------------------
NEWSAPI_KEY=sua_newsapi_key

# ---- API -----------------------------------------------
API_TOKEN=um_token_secreto_qualquer    # Bearer token para POST /bot/*

# ---- CORS (#30) --------------------------------------------
# Lista separada por vírgula. Use * para permitir todas as origens (não recomendado em prod).
# Ex: ALLOWED_ORIGINS=https://roboto-dashboard.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*

# ---- Warmup FinBERT ----------------------------------------
WARMUP_ON_STARTUP=false

# ---- Render Deploy Hook (#30) ------------------------------
# Cole o hook do Render: Service > Settings > Deploy Hook
# Usado pelo CI/CD para disparar deploys automáticos.
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-xxxx?key=yyyy
